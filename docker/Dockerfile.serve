FROM nvidia/cuda:12.1.1-runtime-ubuntu22.04

WORKDIR /app

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip git && \
    rm -rf /var/lib/apt/lists/*

# Python dependencies
COPY pyproject.toml .
RUN pip3 install --no-cache-dir \
    torch transformers accelerate peft bitsandbytes \
    vllm fastapi uvicorn pydantic sse-starlette \
    qdrant-client sentence-transformers \
    pyyaml tqdm rich httpx

# Copy application code
COPY configs/ configs/
COPY src/ src/

# Copy model (mount as volume in production)
# COPY checkpoints/merged/ /models/medllama/

# Expose API port
EXPOSE 8090

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD python3 -c "import httpx; r=httpx.get('http://localhost:8090/health'); assert r.status_code==200"

# Launch API server
CMD ["python3", "-m", "uvicorn", "src.serving.run:app", \
     "--host", "0.0.0.0", "--port", "8090", "--workers", "1"]
